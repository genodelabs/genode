append_if [play_sample_file] config {
+ start test-audio_play | ram: 8M
  + config | sample_path: sample.f32
  | + vfs | + rom sample.f32
  + route
    + any-service
      + parent
      + any-child}

append config {
-}

install_config $config

set boot_modules [build_artifacts]

#
# Get sample file
#

if {![file exists bin/sample.f32] && [play_sample_file]} {
	puts ""
	puts "The sample file is missing. Please take a look at"
	puts "repos/dde_bsd/README, create 'sample.f32' and put"
	puts "the file into './bin' directory."
	puts ""
	exit 1
}

lappend_if [play_sample_file] boot_modules sample.f32

build_boot_image $boot_modules

run_genode_until forever
