  | + policy | label_prefix: logo          | decoration: no
  | + default-policy
  + route
    + service ROM    | label: default.png       | + parent | label: drop_shadow.png
    + service ROM    | label: window_layout     | + child report_rom
    + service ROM    | label: pointer           | + child report_rom
    + service Report | label: decorator_margins | + child report_rom
    + service Report | label: hover             | + child report_rom
    + service Gui                               | + child wm
    + any-service                               | + parent

