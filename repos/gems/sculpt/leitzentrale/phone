    + policy | label: manager -> window_list       | report: wm -> window_list
    + policy | label: manager -> decorator_margins | report: decorator -> decorator_margins
    + policy | label: runtime_view -> main         | report: manager -> main_dialog
    + policy | label: manager -> menu_hover        | report: runtime_view -> hover

+ start wm | caps: 300 | ram: 4M
  + provides
    + service Gui
    + service Report
    + service ROM
  + config
    + policy | label_prefix: decorator | role: decorator
    + default-policy
  + route
    + service ROM | label: resize_request | + child report_rom
    + service ROM | label: focus          | + child report_rom
    + service Report                      | + child report_rom
    + service Gui                         | + child manager
    + any-service
      + parent
      + any-child

