+ start fader_config | ram: 1M
  + binary rom_filter
  + provides | + service ROM
  + config
  | + input leitzentrale_enabled | rom: leitzentrale | node: leitzentrale
  |   + attribute enabled
  | + output | node: config
  |   + if
  |     + has_value | input: leitzentrale_enabled | value: yes
  |     + then
  |       + attribute initial_fade_in_steps | value: 100
  |       + attribute fade_in_steps         | value: 20
  |       + attribute alpha                 | value: 210
  |     + else
  |       + attribute fade_out_steps        | value: 30
  |       + attribute alpha                 | value: 0
  + route
    + service ROM | label: leitzentrale | + parent | label: leitzentrale_enabled
    + any-service                       | + parent

