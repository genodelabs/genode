# configuration decisions
platform: pc
system:   pc
gpu:      intel

# supplemental depot content added to the system image
import: pkg/sculpt_drivers-pc

# selection of option-menu entries
option: download_debug_info black_hole trace_logger
option: audio mixer system_clock acpi_support recall_fs touchpad

# selection of accepted depot-package providers
depot: genodelabs alex-ab chelmuth cnuke cproc jschlatow nfeske skalk ssumpf

# preconfigured example scenarios
presets: empty nano3d window_manager falkon_web_browser goa_testbed
