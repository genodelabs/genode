    + rom | label_prefix: manager -> report -> | + child report
    + rom | label_prefix: report ->            | + child report
    + rom | label_prefix: manager -> config -> | + child model
    + rom | label_prefix: config ->            | + child model
    + fs config                                | + child model
    + fs font                                  | + child font
    + fs report                                | + child report
    + report                                   | + child report
