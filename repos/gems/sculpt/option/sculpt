option

+ child model | binary: init | caps: 300 | ram: 15M | priority: -1
  + provides
    + rom
    + fs
  + connect
    + rom config    | + parent | label: config -> child/model
    + fs            | + parent | identity: config -> rw
    + rom ld.lib.so | + parent
    + rom chroot    | + parent
    + rom fs_rom    | + parent

+ child gui | binary: nitpicker | caps: 1000 | ram: 18M | priority: -1
  + affinity | xpos: 1 | width: 1 | . decouple nitpicker from boot CPU
  + provides
    + gui
    + capture
    + event
  + connect
    + rom config      | + child model | label: child/gui
    + rom focus       | + child gui_focus
    + report keystate | + child report_logger
    + report          | + child report

+ child report_logger | binary: report_rom | ram: 1M | caps: 100 | priority: -1
  + provides
    + report
    + rom
  + config | verbose: yes

+ child numlock_remap | binary: rom_filter | ram: 1M | caps: 100 | priority: -1
  .
  . toggle key mappings depending on the numlock state
  .
  + provides | + rom
  + connect
    + rom config  | + child model  | label: child/numlock_remap
    + rom numlock | + child report | label: global_keys/numlock

+ child event_filter | binary: event_filter | caps: 120 | ram: 2M | priority: -1
  + provides | + event
  + connect
    + event                         | + child gui
    + rom config                    | + child model  | label: child/event_filter
    + rom numlock.remap             | + child numlock_remap
    + rom capslock                  | + child report | label: global_keys/capslock
    + rom | label_prefix: keyboard/ | + parent | identity: config

+ child gui_focus | binary: rom_filter | ram: 1M | caps: 100 | priority: -1
  .
  . override user focus when leitzentrale is active
  .
  + provides | + rom
  + config
  | + input lockscreen_enabled   | rom: hover        | node: hover        | + attribute label
  | + input leitzentrale_enabled | rom: leitzentrale | node: leitzentrale | + attribute enabled
  | + output | node: focus
  |   + if
  |     + has_value | input: lockscreen_enabled | value: lock_screen
  |     + then
  |     | + attribute label | value: lock_screen
  |     + else
  |       + if
  |         + has_value | input: leitzentrale_enabled | value: yes
  |         + then
  |         | + attribute label | value: leitzentrale -> manager -> fader ->
  |         + else
  |           + attribute label | value: focus
  + connect
    + rom hover        | + child report | label: gui/hover
    + rom leitzentrale | + child report | label: global_keys/leitzentrale

+ child font | binary: vfs | caps: 150 | ram: 4M
  + provides | + fs
  + connect
    + rom config         | + child model | label: child/font
    + rom vfs.lib.so     | + parent
    + rom vfs_ttf.lib.so | + parent
    + rom libc.lib.so    | + parent
    + rom libm.lib.so    | + parent
    + rom Vera.ttf       | + parent
    + rom VeraMono.ttf   | + parent

+ child pointer | binary: pointer | ram: 2M | caps: 100 | priority: -1
  + provides | + report
  + config | shapes: yes
  + connect
    + gui       | + child gui
    + rom hover | + child report | label: gui/hover
    + rom xray  | + child report | label: global_keys/xray

+ child global_keys | binary: global_keys_handler | ram: 1M | caps: 100 | priority: -1
  + connect
    + gui        | + child gui
    + rom config | + child model | label: child/global_keys
    + report     | + child report

+ child clipboard | binary: clipboard | ram: 2M | caps: 100 | priority: -1
  + provides
    + rom
    + report
  + connect
    + rom config | + child model  | label: child/clipboard
    + rom focus  | + child report | label: gui/focus

+ child report | binary: init | caps: 1000 | ram: 30M | priority: -1
  + provides
    + log
    + report
    + rom
    + fs
  + connect
    + rom config             | + child model | label: child/report
    + rom runtime_config     | + parent      | label: runtime_config
    + rom runtime_state      | + parent      | label: runtime_state
    + rom kernel_log         | + parent      | label: kernel_log
    + rom core_log           | + parent      | label: core_log
    + rom ld.lib.so          | + parent
    + rom vfs.lib.so         | + parent
    + rom vfs_ram_log.lib.so | + parent
    + rom libc.lib.so        | + parent
    + rom libm.lib.so        | + parent
    + rom vfs                | + parent
    + rom log_core           | + parent
    + rom file_terminal      | + parent
    + rom terminal_log       | + parent
    + rom fs_rom             | + parent
    + rom fs_report          | + parent

