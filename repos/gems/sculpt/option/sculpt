    + rom libpng.lib.so                        | + parent
    + rom zlib.lib.so                          | + parent
    + rom vfs                                  | + parent
    + rom vfs_ttf.lib.so                       | + parent
    + rom backdrop                             | + parent
    + rom terminal                             | + parent
    + rom nitpicker                            | + parent
    + rom gui_fb                               | + parent
    + rom gui_fader                            | + parent
    + rom report_rom                           | + parent
    + rom rom_filter                           | + parent
    + rom wm                                   | + parent
    + rom themed_decorator                     | + parent
    + rom terminal_log                         | + parent
    + rom fs_report                            | + parent
    + rom sculpt_manager                       | + parent
    + rom phone_manager                        | + parent
    + rom stdin2out                            | + parent
    + rom VeraMono.ttf                         | + parent
    + rom genode_logo.png                      | + parent
    + rom drop_shadow.png                      | + parent
    + rom build_info                           | + parent
    + rom platform_info                        | + parent
