##
# ROM routes that relabel generic driver names to platform-specific binaries
#
proc driver_routes { } {

	global driver_routes

	if {[info exists driver_routes([board])]} {
		return $driver_routes([board]); }

	return "";
}


install_config {
config | prio_levels: 2

+ parent-provides
  + service ROM
  + service IRQ
  + service IO_MEM
  + service IO_PORT
  + service PD
  + service RM
  + service CPU
  + service LOG
  + service TRACE
  + service VM

+ affinity-space | width: 2 | height: 1

+ default-route
  + any-service
    + parent
    + any-child
+ default | caps: 100 | ram: 1M

+ resource RAM | preserve: 2M

+ start timer | priority: 0
  + provides | + service Timer

+ start report_rom | priority: -1 | ram: 2M
  + provides
    + service Report
    + service ROM
  + config | verbose: no
    + policy | label: deploy -> blueprint | report: runtime -> blueprint
    + policy | label: runtime -> config   | report: deploy -> runtime
    + policy | label: runtime -> query    | report: deploy -> query
    + policy | label: report_fs -> init   | report: deploy -> runtime
    + policy | label: runtime -> state    | report: runtime -> state

+ start model_fs | caps: 200 | ram: 12M | priority: -1
  + binary vfs
  + provides | + service File_system
  + config
    + vfs
    | + dir orig | + tar model.tar
    | + ram
    | + import
    |   + tar model.tar
    + policy | label_prefix: ro -> | root: /
    + policy | label_prefix: rw -> | root: / | writeable: yes

+ start model_rom | ram: 10M | priority: -1
  + binary fs_rom
  + provides | + service ROM
  + route
    + service File_system | + child model_fs | identity: ro
    + any-service         | + parent

+ start terminal_monitor | ram: 2M | priority: -1
  + binary terminal_crosslink
  + provides | + service Terminal

+ start deploy
  + binary depot_deploy
  + route
    + service ROM | label: config           | + child model_rom | label: runtime
    + service ROM | label: deploy           | + child model_rom | label: deploy
    + service ROM | label: depot            | + child model_rom | label: depot/version
    + service ROM | label: blueprint        | + child report_rom
    + service ROM | label_prefix: option -> | + child model_rom | prepend_resource: option/
    + service Report                        | + child report_rom
    + any-service                           | + parent

+ start runtime | caps: 50000 | ram: 32G | priority: -1 | managing_system: yes
  + binary monitor
  + route
    + service ROM         | label: config          | + child report_rom
    + service ROM         | label: model_config    | + child model_rom | label: child/model
    + service ROM         | label: query           | + child report_rom
    + service ROM         | label: state           | + child report_rom
    + service ROM         | label: kernel_log      | + parent
    + service ROM         | label: core_log        | + parent
    + service Report      | label: state           | + child report_rom
    + service Report      | label: blueprint       | + child report_rom
    + service TRACE       | label: runtime         | + parent | label: runtime ->
    + service TRACE       | label: global          | + parent | label:
    + service File_system | label_prefix: model -> | + child model_fs | identity: rw
    + service Timer                                | + child timer
    } [driver_routes] {
    + service Terminal                             | + child terminal_monitor
    + any-service                                  | + parent
-
}


