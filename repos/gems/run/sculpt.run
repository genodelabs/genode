}

# configs that are expected to be always present
set required_global_configs {
	deploy
	system
	manager
	fb
}

foreach config $required_global_configs {
	set ingredient [single_ingredient $config "default"]
	set from [ingredient_path $config $ingredient]
	set to   [model]/$config
	check_syntax $from
	copy_config $from $to
}

set required_child_configs {
	wifi
	event_filter
	font
	gui
	clipboard
	nic_router
	numlock_remap
	global_keys
	leitzentrale
	usb
	ram_fs
	report
	model
}

foreach config $required_child_configs {
	set ingredient [single_ingredient $config "default"]
	set from [ingredient_path $config $ingredient]
	set to   [model]/child/$config
	check_syntax $from
	copy_config $from $to
}

set from [ingredient_path platform [board]]
set to   [model]/child/platform
check_syntax $from
copy_config $from $to

# optional child configs that are managed by the sculpt manager if absent
set optional_configs {
	gpu
}

foreach config $optional_configs {
	set ingredient [single_ingredient $config ""]
	if {$ingredient != ""} {
		set from [ingredient_path $config $ingredient]
		set to   [model]/child/$config
		copy_config $from $to } }

##
# Return list of deploy files
#
proc deploy_files { } {

	set deploy_files [model]/deploy
	foreach preset [ingredients_of_type presets] {
		lappend deploy_files [ingredient_path deploy $preset] }
	return $deploy_files
}

##
# Return list of used deploy options
#
proc deploy_options { } {

	global _deploy_options

	if {[info exists _deploy_options]} { return $_deploy_options }

	# explicitely listed options
	lappend _deploy_options {*}[ingredients_of_type option]

	# gather options used in presets and deploy
	foreach path [deploy_files] {

		validate_hid [genode_dir]/repos/gems/src/app/depot_deploy/deploy.hsd $path

		set cmd [genode_dir]/tool/hid
		if {[looks_like_xml $path]} { lappend cmd --import-xml --output-xml }

		set names {}
		if {[catch {
			set names [split [exec {*}$cmd get "deploy | + option | : name" $path] "\n"]
			lappend _deploy_options {*}$names
		}]} {
			puts stderr "failed to parse $path for gathering deploy options"
			exit 1
		}
	}

	# remove duplicates
	set _deploy_options [lsort -unique $_deploy_options]

	foreach opt $_deploy_options {
		validate_hid [genode_dir]/repos/gems/src/app/depot_deploy/option.hsd \
		             [ingredient_path option $opt] }

	return $_deploy_options
}

# selection of depot users (pubkey and download files), options, and presets
foreach ingredient [ingredients_of_type depot] {
	set from [ingredient_path depot $ingredient]
	set to   [model]/depot/$ingredient
	copy_file $from $to }

foreach opt [deploy_options] {
	set from [ingredient_path option $opt]
	set to   [model]/option/$opt
	copy_config $from $to }

foreach ingredient [ingredients_of_type presets] {
	set from [ingredient_path deploy $ingredient]
	set to   [model]/presets/$ingredient
	copy_config $from $to }

copy_file [genode_dir]/repos/gems/recipes/pkg/sculpt/README [model]/README
copy_file [genode_dir]/repos/gems/run/sculpt/vimrc          [model]/vimrc

# keyboard layouts
foreach file { en_us de_ch de_de fr_ch fr_fr fr_bepo special } {
	set from [genode_dir]/repos/os/src/server/event_filter/$file.chargen
	set to   [model]/keyboard/$file
	check_syntax $from
	copy_config $from $to }

install_hid [model]/install "install | managed: yes | arch: [depot_spec]\n-"
install_hid [model]/child/depot_query     "query\n-"
install_hid [model]/child/blueprint_query "query\n-"
install_hid [model]/depot/version "depot | managed: yes | version: 1\n-"

# dummy kernel/core log ROMs for kernels w/o log-export feature
if {![have_spec nova]}  { install_hid [run_dir]/genode/kernel_log "" }
if {[have_board linux]} { install_hid [run_dir]/genode/core_log   "" }


#
# VERSION file at the root of the config fs, add newline for 'cat /VERSION'
#

set fd [open [model]/VERSION w]
puts $fd "[sculpt_version]"
close $fd

# supply VERSION as a boot module to the sculpt manager
file copy [model]/VERSION [run_dir]/genode/VERSION


#
# Generate build info as boot module
#

proc build_date { } { return [clock format [clock seconds] -format %Y-%m-%d] }

proc genode_version { } {

	if {[have_installed git] && [file exists [file join [genode_dir] .git]]} {
		return [exec [installed_command git] -C [genode_dir] describe \
		       {--dirty= <local changes>} 2> /dev/null] }

	set fh [open [file join [genode_dir] VERSION] "RDONLY"]
	set version [read $fh]
	close $fh

	regsub -all {\s} $version "" version
	return $version
}

set    build_info "build_info\n"
append build_info "  genode_version: [genode_version]\n"
append build_info "  date:           [build_date]\n"
append build_info "  depot_user:     [depot_user]\n"
append build_info "  arch:           [depot_spec]\n"
append build_info "  board:          $board_var\n"
append build_info "  base:           [depot_user]/bin/[depot_spec]/[base_src]/[_current_depot_archive_version src [base_src]]\n"
append build_info "-"

install_hid [run_dir]/genode/build_info $build_info


##
# Return list of 'pkg' attribute values found in 'type' nodes in an XML or HRD file
#
proc pkg_attribute_values { file node_path } {

	set cmd [genode_dir]/tool/hid
	if {[looks_like_xml $file]} { lappend cmd "--import-xml" }

	set result [split [exec {*}$cmd get "$node_path | : pkg" $file] "\n"]
	return $result
}


##
# Return list of pkg archives reference by the options and deploy config
#
proc referenced_pkg_values { } {

	set values {}

	# scan options
	foreach opt [deploy_options] {
		set path [model]/option/$opt
		lappend values {*}[pkg_attribute_values $path "option | + child"]
	}

	# scan presets
	foreach preset [ingredients_of_type presets] {
		set path [model]/presets/$preset
		lappend values {*}[pkg_attribute_values $path "config | + start"]
		lappend values {*}[pkg_attribute_values $path "deploy | + child"]
	}

	# scan deploy config
	lappend values {*}[pkg_attribute_values [model]/deploy "config | + start"]
	lappend values {*}[pkg_attribute_values [model]/deploy "deploy | + child"]

	return [lsort -unique $values]
}


#
# Replace pkg values of the form "name" by the form "user/pkg/name" suitable as
# arguments for '_collect_from_depot'.
#
proc pkg_archive_paths { values } {

	set result {}
	foreach value $values {
		if {[regexp {/} $value dummy]} {
			lappend result $value
		} else {
			lappend result "[depot_user]/pkg/$value"
		}
	}
	return $result
}


##
# Return which kind of depot archive is wanted: 'tar', 'omit', or 'list'
#
# tar  - includes the depot content referenced by the deploy configuration as
#        tar archive named 'depot.tar'
#
# omit - skips the evaluation of the deploy configuration
#
# list - outputs the list of packages needed for the deployment, which can
#        taken as input for manually publishing those packages
#
proc depot_archive { } {

	global ::env

	set archive "tar"
	if {[info exists ::env(DEPOT)]} {
		set archive "$::env(DEPOT)" }

	if {$archive != "omit" && $archive != "tar" && $archive != "list"} {
		puts stderr "Error: invalid value of DEPOT=$archive variable!" }

	return $archive
}


#
# Trigger the creation / updating of referenced depot content
#
# This step may update pkg versions if '--depot-auto-update' is enabled.
#
if {[depot_archive] == "tar" || [depot_archive] == "list"} {
	_collect_from_depot [pkg_archive_paths [referenced_pkg_values]]
}


#
# Augment deploy config and option files with current package versions
#

proc current_pkg { pkg } { return $pkg/[_current_depot_archive_version pkg $pkg] }


proc versioned_pkg { pkg } {

	if {[regexp [_depot_archive_versioned_path_pattern] $pkg dummy user type] && $type == "pkg"} {
		return $pkg
	} elseif {[regexp [_depot_archive_path_pattern] $pkg dummy user type name] && $type == "pkg"} {
		return $user/pkg/[current_pkg $name]
	} elseif {![regexp {/} $pkg dummy]} {
		return [depot_user]/pkg/[current_pkg $pkg]
	} else {
		puts stderr "Error: malformed depot-archive path '$pkg',"
		puts stderr "       expected '<user>/pkg/<name>' or"
		puts stderr "                '<name>' or"
		puts stderr "                '<user>/pkg/<name>/<version>'"
		exit
	}
}


proc augment_child_node_pkg_versions { toplevel path } {

	set cmd [genode_dir]/tool/hid
	if {[looks_like_xml $path]} { lappend cmd --import-xml --output-xml }

	if {[catch {
		set names [split [exec {*}$cmd get "$toplevel | + child | : name" $path] "\n"]

		foreach name $names {
			set pkg [exec {*}$cmd get "$toplevel | + child $name | : pkg" $path]
			if {$pkg != ""} { # skip children deployed from ROM
				exec {*}$cmd -i set "$toplevel | + child $name | : pkg: [versioned_pkg $pkg]" $path
			}
		}
	}]} {
		puts stderr "failed to parse $path for augmenting pkg versions"
		exit
	}
}


proc augment_start_node_pkg_versions { path } {

	set cmd [genode_dir]/tool/hid
	if {[looks_like_xml $path]} { lappend cmd --import-xml --output-xml }

	if {[catch {
		set names [split [exec {*}$cmd get "config | + start | : name" $path] "\n"]

		foreach name $names {
			set pkg [exec {*}$cmd get "config | + start $name | : pkg" $path]
			exec {*}$cmd -i set "config | + start $name | : pkg: [versioned_pkg $pkg]" $path
		}
	}]} {
		puts stderr "failed to parse $path for augmenting pkg versions"
		exit
	}
}

# options
foreach opt [deploy_options] {
	augment_child_node_pkg_versions "option" [model]/option/$opt }

# presets
foreach preset [ingredients_of_type presets] {
	augment_child_node_pkg_versions "deploy" [model]/presets/$preset
	augment_start_node_pkg_versions          [model]/presets/$preset
}

# deploy config
augment_child_node_pkg_versions "deploy" [model]/deploy
augment_start_node_pkg_versions          [model]/deploy


##
## Depot content integrated in the Sculpt image
##

proc create_depot_archive { } {

	if {[depot_archive] == "tar"} {
		create_tar_from_depot_binaries [run_dir]/genode/depot.tar \
		                               {*}[pkg_archive_paths [referenced_pkg_values]]

	} else {
		create_tar_from_depot_binaries [run_dir]/genode/depot.tar
		if {[depot_archive] == "list"} {
			puts "Do not forget to publish:"
			puts [pkg_archive_paths [referenced_pkg_values]]
		}
	}
}

create_depot_archive


#
# Create model.tar to be mounted at the root of the model fs
#

exec sh -c "tar cf [run_dir]/genode/model.tar -C [model] ."

file delete -force [model]


##
## Auxiliary boot modules
##

#
# Linux-specific tweaks
#
if {[have_board linux]} {

	#
	# The Linux version of core does not export a platform_info ROM module.
	#
	install_boot_module "platform_info" "platform\n-\n"
}


# support for the Leitzentrale GUI
copy_file [genode_dir]/repos/gems/src/app/backdrop/genode_logo.png [run_dir]/genode/
copy_file [genode_dir]/repos/gems/run/sculpt/drop_shadow.png       [run_dir]/genode/


#
# Generate depot index from gems/run/sculpt/index
#

set fd [open [genode_dir]/repos/gems/run/sculpt/index r]
set pkg_index [read $fd]
close $fd

# filter 'pkg' attribute
set pattern { pkg [|] path: ([^/ |]+) }
while {[regexp $pattern $pkg_index dummy pkg]} {
	set pkg_path [depot_user]/pkg/[current_pkg $pkg]
	regsub $pattern $pkg_index " pkg | path: $pkg_path " pkg_index
}

# write filtered pkg index into the depot
file mkdir [depot_dir]/[depot_user]/index
set fd [open [depot_dir]/[depot_user]/index/[sculpt_version] w]
puts $fd $pkg_index
close $fd


##
## Create boot image
##

build [ingredients_of_type build]

append boot_modules [build_artifacts]

build_boot_image $boot_modules
