	if {[log_core]} { return "parent" } else { return "child report" }
}

install_hid [model]/runtime {
config | arch: } [depot_spec] { | verbose: no | prio_levels: 8 | depot_rom: depot_rom
+ report  | init_ram: yes | init_caps: yes | child_ram: yes | child_caps: yes
          | requested: no | provided: no | delay_ms: 2000 | buffer: 1M
+ heartbeat | rate_ms: 2000
+ static
  + parent-provides
    + service ROM
    + service CPU
    + service PD
    + service RM
    + service LOG
    + service VM
    + service Timer
    + service Report
    + service File_system
    + service TRACE
    + service IO_MEM
    + service IO_PORT
    + service IRQ
    + service Terminal
+ common_routes
  + service ROM | label_last: ld.lib.so | + parent
  + service ROM | label_last: init      | + parent
  + service CPU                         | + parent
  + service PD                          | + parent
  + service LOG                         | + } [log_route] {
  + service Timer                       | + parent
