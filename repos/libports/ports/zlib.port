LICENSE   := zlib
VERSION   := 1.3.2
DOWNLOADS := zlib.archive

URL(zlib) := https://zlib.net/zlib-$(VERSION).tar.xz
SHA(zlib) := d7a0654783a4da529d1bb793b7ad9c3318020af77667bcae35f95d0e42a792f3
SIG(zlib) := ${URL(zlib)}.asc
DIR(zlib) := src/lib/zlib

DIRS := include/zlib
DIR_CONTENT(include/zlib) := $(addprefix src/lib/zlib/,zconf.h zlib.h)
