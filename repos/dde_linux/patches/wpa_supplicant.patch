 		  struct nl_sock *nl_handle, struct nl_msg *msg,
 		  int (*valid_handler)(struct nl_msg *, void *),
@@ -579,7 +581,7 @@
 	/* Always clear the message as it can potentially contain keys */
 	nl80211_nlmsg_clear(msg);
 	nlmsg_free(msg);
-	return err.err;
+	return convert_errno_from_linux(err.err);
 }
 
 
