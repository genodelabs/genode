Encode stream direction in signal number of 'snd_kill_fasync' in order to
distinguish play from capture interrupts in Intel SOF driver.

--- src/linux/sound/core/pcm_lib.c
+++ src/linux/sound/core/pcm_lib.c
@@ -1914,7 +1914,7 @@ void snd_pcm_period_elapsed_under_stream_lock(struct snd_pcm_substream *substrea
 		snd_timer_interrupt(substream->timer, 1);
 #endif
  _end:
-	snd_kill_fasync(runtime->fasync, SIGIO, POLL_IN);
+	snd_kill_fasync(runtime->fasync, substream->stream, POLL_IN);
 }
 EXPORT_SYMBOL(snd_pcm_period_elapsed_under_stream_lock);
 
